# General
XUI_DEBUG=false
XUI_DB_FOLDER=x-ui
XUI_LOG_FOLDER=x-ui
XUI_BIN_FOLDER=x-ui

# Database type: "sqlite" (default) or "mysql"
XUI_DB_TYPE=mysql

# MySQL connection (only used when XUI_DB_TYPE=mysql)
XUI_MYSQL_HOST=127.0.0.1
XUI_MYSQL_PORT=3306
XUI_MYSQL_USER=root
XUI_MYSQL_PASSWORD=changeme
XUI_MYSQL_DBNAME=x-ui

# MySQL performance tuning (optional, defaults shown)
# XUI_MYSQL_MAX_OPEN_CONNS=25
# XUI_MYSQL_MAX_IDLE_CONNS=10
# XUI_MYSQL_CONN_MAX_LIFETIME=300
# XUI_MYSQL_CONNECT_TIMEOUT=10
# XUI_MYSQL_READ_TIMEOUT=30
# XUI_MYSQL_WRITE_TIMEOUT=30
